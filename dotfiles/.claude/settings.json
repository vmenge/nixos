{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:docs.rs)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:crates.io)",
      "WebFetch(domain:man7.org)",
      "WebFetch(domain:www.freedesktop.org)",
      "Read(//home/vmenge/.agents/AGENTS.md)",
      "Bash(cargo check:*)"
    ],
    "additionalDirectories": [
      "/home/vmenge/.agents"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/home/vmenge/.claude/hooks/gsd-check-update.js\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/home/vmenge/.claude/hooks/gsd-context-monitor.js\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node \"/home/vmenge/.claude/hooks/gsd-statusline.js\""
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  },
  "skipDangerousModePermissionPrompt": true
}
