; [url "ssh://git@github.com/"]
; 	insteadof = https://github.com/
[filter "lfs"]
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
[safe]
	directory = /tmp/test-repo-W1Y1YD
[core]
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	dark = true
	side-by-side = true
[merge]
	conflictStyle = zdiff3
