// -*- mode: jsonc -*-
{
  "layer": "top",
  "position": "bottom",
  "height": 26,
  "spacing": 0,
  "margin-bottom": 8,
  "margin-left": 8,
  "margin-right": 8,

  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["clock"],
  "modules-right": [
    "custom/voxtype",
    "tray",
    "idle_inhibitor",
    "pulseaudio",
    "network",
    "cpu",
    "memory",
    "temperature",
    "battery"
  ],

  "include": ["~/.config/waybar/modules.json"]
}
