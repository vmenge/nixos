  },

  "temperature": {
    "interval": 10,
    "hwmon-path": [
      "/sys/devices/platform/coretemp.0/hwmon/hwmon8/temp1_input",
      "/sys/devices/platform/coretemp.0/hwmon/hwmon7/temp1_input",
      "/sys/devices/platform/coretemp.0/hwmon/hwmon6/temp1_input",
      "/sys/devices/platform/coretemp.0/hwmon/hwmon5/temp1_input",
      "/sys/devices/platform/coretemp.0/hwmon/hwmon4/temp1_input",
      "/sys/devices/platform/coretemp.0/hwmon/hwmon3/temp1_input"
    ],
    "critical-threshold": 90,
    "format": "َ°”ڈ {temperatureC}آ°C",
    "format-critical": "َ±ƒ‚ {temperatureC}آ°C"
  },

  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "َ°‚„ {capacity}%",
    "format-plugged": "َ°ڑ¥ {capacity}%",
    "format-alt": "{icon} {time}",
    "format-icons": ["َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"]
  },

  "clock": {
    "format": "َ°ƒ® {:%a %d %b  َ°…گ %H:%M}",
    "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>",
    "format-alt": "{:%Y-%m-%d}"
  }
}
