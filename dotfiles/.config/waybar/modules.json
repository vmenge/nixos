{
  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "warp-on-scroll": false,
    "format": "{id}",
    "persistent-workspaces": {
      "*": 5
    }
  },

  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "َ°…¶",
      "deactivated": "َ°¾ھ"
    }
  },

  "tray": {
    "spacing": 8
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-bluetooth": "َ°‚¯ {volume}%",
    "format-bluetooth-muted": "َ°‚²",
    "format-muted": "َ°‌ں",
    "format-icons": {
      "headphone": "َ°‹‹",
      "headset": "َ°‹ژ",
      "default": ["َ°•؟", "َ°–€", "َ°•¾"]
    },
    "on-click": "pavucontrol"
  },

  "network": {
    "format-wifi": "َ°¤¨ {essid}",
    "format-ethernet": "َ°ˆ€ {ipaddr}",
    "format-linked": "َ°ˆ‚ {ifname}",
    "format-disconnected": "َ°¤­",
    "tooltip-format": "{ifname} via {gwaddr}\n{ipaddr}/{cidr}\nStrength: {signalStrength}%"
  },

  "cpu": {
    "format": "َ°»  {usage}%",
    "tooltip": true
  },

  "memory": {
    "format": "َ°چ› {percentage}%",
