[global]
    monitor         = 0
    follow          = mouse

    # Geometry
    width           = (300, 500)
    height          = 300
    origin          = top-right
    offset          = 12x12
    scale           = 0
    notification_limit = 5

    # Progress bar
    progress_bar             = true
    progress_bar_height      = 6
    progress_bar_frame_width = 1
    progress_bar_min_width   = 150
    progress_bar_max_width   = 300

    # Appearance
    gap_size           = 6
    padding            = 12
    horizontal_padding = 12
    text_icon_padding  = 12
    separator_height   = 2
    separator_color    = frame
    frame_width        = 2
    frame_color        = "#1a1b26"
    corner_radius      = 10
    transparency       = 0

    # Text
    font               = DepartureMono Nerd Font 11
    line_height        = 0
    markup             = full
    format             = "<b>%s</b>\n%b"
    alignment          = left
    vertical_alignment = center
    ellipsize          = middle
    show_age_threshold = 60
    stack_duplicates   = true
    show_indicators    = yes

    # Icons
    enable_recursive_icon_lookup = true
    icon_theme    = Adwaita
    icon_position = left
    min_icon_size = 32
    max_icon_size = 64

    # History
    sticky_history = yes
    history_length = 20

    # Misc
    title  = Dunst
    class  = Dunst
    layer  = overlay
    sort   = yes

    always_run_script  = true
    ignore_dbusclose   = false
    force_xwayland     = false

    # Mouse
    mouse_left_click   = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click  = close_all

[urgency_low]
    background  = "#000000cc"
    foreground  = "#ffffff"
    frame_color = "#1a1b26"
    timeout     = 4

[urgency_normal]
    background  = "#000000cc"
    foreground  = "#ffffff"
    frame_color = "#1a1b26"
    timeout     = 8

[urgency_critical]
    background  = "#000000cc"
    foreground  = "#ff5555"
    frame_color = "#ff5555"
    timeout     = 0
